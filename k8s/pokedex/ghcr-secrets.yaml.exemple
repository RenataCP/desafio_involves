apiVersion: v1
kind: Secret
metadata:
  name: ghcr-secret
  namespace: pokedex

type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "ghcr.io": {
          "username": "<Github Username>",
          "password": "<CLASSIC_PAT_READ_PACKAGES>"
        }
      }
    }